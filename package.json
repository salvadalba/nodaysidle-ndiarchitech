{
  "name": "prd-compiler",
  "private": true,
  "version": "0.6.0",
  "type": "module",
  "bin": {
    "prd": "./dist/cli.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "cli:build": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.js --external:ora --external:chalk --external:commander",
    "cli:dev": "npx tsx src/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "esbuild": "^0.27.2",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/cli": "^2.9.6",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-sql": "^2.3.1",
    "@types/d3": "^7.4.3",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "d3": "^7.9.0",
    "ora": "^9.1.0"
  }
}
